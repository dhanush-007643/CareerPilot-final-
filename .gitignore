# ── Dependencies ──────────────────────────────────────────────
node_modules/

# ── Environment variables ─────────────────────────────────────
.env
.env.local
.env.*.local

# ── Uploads ───────────────────────────────────────────────────
backend/public/uploads/*
!backend/public/uploads/.gitkeep

# ── Build outputs ─────────────────────────────────────────────
frontend/dist/

# ── Logs ──────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*

# ── OS files ──────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Vercel ────────────────────────────────────────────────────
.vercel/

# ── Docker ────────────────────────────────────────────────────
*.pem
docker-compose.override.yml

# ── Kubernetes secrets (never commit real secrets) ────────────
# k8s/secret.yaml is a TEMPLATE with placeholder values — safe to commit
# If you create a k8s/secret-real.yaml with actual values, it's ignored:
k8s/secret-real.yaml
