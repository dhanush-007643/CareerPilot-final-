# ═══════════════════════════════════════════════════════════════════════════
# CareerPilot Backend — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your real values.
# ═══════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── MongoDB Atlas ─────────────────────────────────────────────────────────
# 1. Go to https://cloud.mongodb.com → Create a free cluster
# 2. Create a database user (Database Access)
# 3. Whitelist 0.0.0.0/0 (Network Access) for Render
# 4. Click "Connect" → "Connect your application" → copy the URI
MONGO_URI=mongodb+srv://careerpilot:1_Dha_anush9@careerpilotcluster.zr7jey0.mongodb.net/?appName=CareerPilotCluster

# ── JWT Authentication ────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<generate-a-strong-random-string>
JWT_EXPIRE=30d

# ── Email (Nodemailer + Gmail) ────────────────────────────────────────────
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an App Password for "Mail"
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── Public URLs ───────────────────────────────────────────────────────────
CLIENT_URL=https://careerpilot.vercel.app
SERVER_URL=https://careerpilot-api.onrender.com

# ── Cloudinary (Resume & Image Uploads) ──────────────────────────────────
# 1. Sign up at https://cloudinary.com (free tier = 25 GB)
# 2. Go to Dashboard → copy Cloud Name, API Key, API Secret
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_KEY=your_api_key
CLOUDINARY_SECRET=your_api_secret

# ── AWS S3 (Legacy — optional, only needed if NOT using Cloudinary) ──────
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_S3_BUCKET=careerpilot-resumes
