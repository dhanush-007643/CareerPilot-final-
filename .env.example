# ═══════════════════════════════════════════════════════════════════════════
# CareerPilot — Environment Variables Reference
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file and fill in your values.
#   Backend  → backend/.env
#   Frontend → frontend/.env
#
# NEVER commit real credentials to Git. The .gitignore already excludes .env
# ═══════════════════════════════════════════════════════════════════════════

# ── Backend ───────────────────────────────────────────────────────────────

PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/careerpilot?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=<generate-a-strong-random-string>
JWT_EXPIRE=30d

# Email (Gmail SMTP via App Password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Public URLs
CLIENT_URL=https://careerpilot.vercel.app
SERVER_URL=https://careerpilot-api.onrender.com

# Cloudinary (Resume & Image Uploads — FREE tier)
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_KEY=your_api_key
CLOUDINARY_SECRET=your_api_secret

# AWS S3 (Legacy — optional, only if NOT using Cloudinary)
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=careerpilot-resumes

# ── Frontend ──────────────────────────────────────────────────────────────

VITE_API_URL=https://careerpilot-api.onrender.com/api
VITE_SOCKET_URL=https://careerpilot-api.onrender.com
